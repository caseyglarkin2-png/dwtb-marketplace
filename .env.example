# ==========================================================
# DWTB?! Studios — Environment Variables
# ==========================================================

# --- Supabase (REQUIRED for persistence) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (rate limiting) ---
# If not set, rate limiting is disabled (dev-mode friendly)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Resend (email notifications) ---
# If not set, email sends are skipped silently
RESEND_API_KEY=

# --- Admin Dashboard ---
# ADMIN_PASSWORD: password for /admin login
# ADMIN_SECRET: HMAC signing key for session cookies (generate: openssl rand -hex 32)
ADMIN_PASSWORD=
ADMIN_SECRET=

# --- App Config ---
NEXT_PUBLIC_SITE_URL=https://dwtb.dev

# --- Video (optional) ---
# Set to embed URL when Casey's video is ready
NEXT_PUBLIC_VIDEO_URL=

# --- Bid Limits ---
MAX_BID_AMOUNT=500000

# --- Feature Flags ---
# Set to "true" to require invite tokens for /partners access
REQUIRE_INVITE_TOKEN=false
